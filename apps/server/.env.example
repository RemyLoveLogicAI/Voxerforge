# VoxForge Server Environment Variables

# Server Configuration
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voxforge

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS
CORS_ORIGIN=https://voxforge.example.com

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379

# AI Providers (Optional - for cloud models)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Ollama (Local AI)
OLLAMA_BASE_URL=http://localhost:11434

# Logging
LOG_LEVEL=info

# File Upload
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@voxforge.example.com

# Push Notifications
PUSH_NOTIFICATION_KEY=

# Monitoring
SENTRY_DSN=
