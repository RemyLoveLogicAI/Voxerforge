{
  "name": "@voxforge/server",
  "version": "0.1.0",
  "description": "VoxForge IDE Backend Server - Production-grade API and WebSocket server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["voxforge", "server", "api"],
  "license": "MIT",
  "dependencies": {
    "@voxforge/core": "workspace:*",
    "@voxforge/ai-orchestrator": "workspace:*",
    "@voxforge/code-ops": "workspace:*",
    "@voxforge/rag-engine": "workspace:*",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.8.0",
    "@prisma/client": "^5.8.0",
    "redis": "^4.6.12",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
